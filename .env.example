# ──────────────────────────────────────────────
# Database
# Neon (free tier works), Supabase, or any Postgres
# Use the pooled connection string with sslmode=require
# ──────────────────────────────────────────────
DATABASE_URL="postgresql://<user>:<password>@<host>/<db>?sslmode=require"

# ──────────────────────────────────────────────
# Better Auth
# Generate BETTER_AUTH_SECRET with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ──────────────────────────────────────────────
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# ──────────────────────────────────────────────
# Google OAuth (optional)
# 1. https://console.cloud.google.com/apis/credentials
# 2. Create Credentials -> OAuth client ID -> Web application
# 3. Authorized redirect URI: http://localhost:3000/api/auth/callback/google
# 4. (For prod) add: https://<your-domain>/api/auth/callback/google
# ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ──────────────────────────────────────────────
# App
# ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ──────────────────────────────────────────────
# Optional: Vercel Blob for expense receipt uploads
# Without it, expense creation works but file upload returns 503
# https://vercel.com/storage/blob
# ──────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=""

# ──────────────────────────────────────────────
# Optional: when running the Fulcru server itself, the MCP importer
# excludes Codex/Claude sessions whose cwd matches this path so your
# self-development sessions never get billed to a client.
# Defaults to process.cwd() if unset.
# ──────────────────────────────────────────────
# FULCRU_SELF_CWD="/absolute/path/to/your/fulcru/checkout"
